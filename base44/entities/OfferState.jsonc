{
  "name": "OfferState",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "description": "Optional notes or description for this offer state record",
      "maxLength": 1000
    },
    "user_id": {
      "type": "string",
      "description": "Unique index \u2014 one row per user"
    },
    "free_tokens_used_total": {
      "type": "number",
      "default": 0
    },
    "purchase_count": {
      "type": "number",
      "default": 0
    },
    "starter_offer_seen_at": {
      "type": "string"
    },
    "starter_offer_claimed_at": {
      "type": "string"
    },
    "heavy_offer_seen_at": {
      "type": "string"
    },
    "heavy_offer_claimed_at": {
      "type": "string"
    },
    "config_version": {
      "type": "string",
      "default": "v1"
    }
  },
  "required": [
    "user_id"
  ]
}